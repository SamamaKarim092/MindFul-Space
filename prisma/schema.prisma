// Prisma schema for the Mental Health Journal app.
// This file defines the database structure: tables, fields, relations, and enums.
// Prisma uses it to generate the client that the backend uses to read and write data.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Users are shared between Supabase Auth and this database.
// Each user can have many journal entries and chats.
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  entries Entry[]
  chats   Chat[]

  @@map("users")
}

// A journal entry belongs to one user.
// It stores the text, mood, sentiment, tags, and optional custom mood labels.
model Entry {
  id        String          @id @default(uuid()) @db.Uuid
  userId    String          @map("user_id") @db.Uuid
  title     String
  content   String          @db.Text
  mood      Mood?           // Made optional - only set if hardcoded mood selected
  sentiment Float?          // AI-computed sentiment score (-1 to 1)
  customMoodLabel String?   @map("custom_mood_label") // For AI-suggested custom moods
  moodLabels String[]       @default([]) @map("mood_labels") // All selected mood labels
  tags      String[]        @default([])
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  // Relations
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments Attachment[]
  chats       Chat[]        // Chats started from this entry

  @@index([userId])
  @@index([createdAt])
  @@index([mood])
  @@map("entries")
}

// Basic mood groups used across the app.
enum Mood {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

// Attachments store file metadata for files linked to a journal entry.
// The actual file lives in Supabase Storage; the database stores the reference.
model Attachment {
  id        String   @id @default(uuid()) @db.Uuid
  entryId   String   @map("entry_id") @db.Uuid
  fileName  String   @map("file_name")
  fileUrl   String   @map("file_url")
  fileType  String   @map("file_type")
  fileSize  Int      @map("file_size")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  entry Entry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@index([entryId])
  @@map("attachments")
}

// A chat belongs to one user and can optionally be tied to one journal entry.
// That lets the app start a conversation from a specific journal entry.
model Chat {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  title          String    @default("New Chat")
  contextEntryId String?   @map("context_entry_id") @db.Uuid  // Links to journal entry that started this chat
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contextEntry Entry?    @relation(fields: [contextEntryId], references: [id], onDelete: SetNull)
  messages     Message[]

  @@index([userId])
  @@index([createdAt])
  @@index([contextEntryId])
  @@map("chats")
}

// Messages belong to a chat.
// This separate table makes it easier to store full conversation history.
model Message {
  id        String      @id @default(uuid()) @db.Uuid
  chatId    String      @map("chat_id") @db.Uuid
  role      MessageRole
  content   String      @db.Text
  createdAt DateTime    @default(now()) @map("created_at")

  // Relations
  chat Chat @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([createdAt])
  @@map("messages")
}

// Role of each message in a chat conversation.
enum MessageRole {
  USER
  AI
  SYSTEM
}

// Quotes and tips shown in the app.
model Quote {
  id        String    @id @default(uuid()) @db.Uuid
  text      String    @db.Text
  author    String    @default("Unknown")
  type      QuoteType @default(QUOTE)
  mood      Mood      @default(POSITIVE)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("quotes")
}

// Different kinds of quote content used by the app.
enum QuoteType {
  QUOTE
  TIP
}
