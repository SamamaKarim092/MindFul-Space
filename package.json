{
  "name": "mental-health-journal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=web",
    "dev:api": "turbo run dev --filter=api",
    "db:generate": "turbo run db:generate --filter=@repo/prisma",
    "db:push": "turbo run db:push --filter=@repo/prisma",
    "db:migrate": "turbo run db:migrate --filter=@repo/prisma",
    "legacy:dev": "node src/server.js",
    "legacy:start": "node src/server.js"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "legacy-dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "firebase": "^12.0.0",
    "mongoose": "^8.14.3"
  }
}
